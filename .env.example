# VCS provider selection (resolved via [vcs].type in reflex_reviewer.toml)
VCS_TYPE=bitbucket

# Generic VCS context (resolved via [vcs] in reflex_reviewer.toml)
VCS_BASE_URL=https://bitbucket.example.com
VCS_PROJECT_KEY=PROJECT
VCS_REPO_SLUG=repository-name
VCS_PR_ID=
VCS_TOKEN=

# OAuth2 (resolved via [oauth2] in reflex_reviewer.toml)
OAUTH2_USER_ID=
OAUTH2_USER_SECRET=

# OAuth2 (fallback vars)
OAUTH2_TOKEN_URL=https://iam.example.com/oauth2/v1/token
OAUTH2_TOKEN_CACHE_FILE=scripts/.idcs_oauth_token_cache.json
OAUTH2_REFRESH_BUFFER_SECONDS=60
OAUTH2_TOKEN_LITELLM_SCOPE=

# LiteLLM endpoint (resolved via [litellm] in reflex_reviewer.toml)
LITELLM_BASE_URL=https://litellm.example.com
# Optional LiteLLM API key. When set, this is used instead of OAuth2 token.
LITELLM_API_KEY=
# Optional proxy for LiteLLM calls
# LITELLM_PROXY_URL=http://www-proxy-example.com.com:80
# Responses API reasoning effort: low | medium | high
LITELLM_REASONING_EFFORT=high


# Model/runtime controls (resolved via [model] in reflex_reviewer.toml)
PRIMARY_MODEL=
STREAM_RESPONSE=false

# chat_completions (default/stateless) | responses (stateful; use only if org/backend supports it)
MODEL_ENDPOINT=chat_completions
