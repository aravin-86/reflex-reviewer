# VCS provider selection (resolved via [vcs].type in reflex_reviewer.toml)
VCS_TYPE=bitbucket

# Generic VCS context (resolved via [vcs] in reflex_reviewer.toml)
VCS_BASE_URL=https://bitbucket.example.com
VCS_PROJECT_KEY=PROJECT
VCS_REPO_SLUG=repository-name
VCS_PR_ID=
VCS_TOKEN=

# OAuth2 (resolved via [oauth] in reflex_reviewer.toml)
# Required only when LLM_API_KEY is not set.
OAUTH2_TOKEN_URL=https://iam.example.com/oauth2/v1/token
OAUTH2_USER_ID=
OAUTH2_USER_SECRET=

# LLM API endpoint (resolved via [llm_api] in reflex_reviewer.toml)
# Required by review/distill/refine flows and build-pipeline step scripts.
LLM_API_BASE_URL=https://llm-api.example.com
# Optional proxy URL for outbound LLM API calls.
LLM_API_PROXY_URL=
# Optional LLM API key. When set, this is used instead of OAuth2 token.
LLM_API_KEY=
# Optional socket read timeout (seconds) for LLM API calls.
LLM_API_READ_TIMEOUT_SECONDS=120

# Model/runtime controls (resolved via [model] in reflex_reviewer.toml)
DRAFT_MODEL=
JUDGE_MODEL=
STREAM_RESPONSE=false
DPO_TRAINING_DATA_DIR=data
# Optional explicit interpreter override for pipeline step scripts.
# Leave empty to use mode default runtime.
# package mode default: <cwd>/.reflex-reviewer-venv/bin/python
# clone mode default: <repo>/.venv/bin/python
PYTHON_BIN=
RR_VENV_DIR=

# Build Pipeline runtime mode (resolved via [pipeline_runtime] in reflex_reviewer.toml)
# package (default): pip install RR_PACKAGE_INSTALL_TARGET in runtime venv
# clone: clone RR_REPOSITORY_CLONE_URL and install from cloned requirements.txt
RR_PIPELINE_INSTALL_MODE=package
# Any pip-installable target: package name, pinned version, wheel URL/path, or git URL.
RR_PACKAGE_INSTALL_TARGET=reflex-reviewer
# Package-mode pip primary index URL (default: TestPyPI).
RR_PACKAGE_INDEX_URL=https://test.pypi.org/simple/
# Package-mode pip extra index URL (default fallback: PyPI). Keep empty to disable extra index.
RR_PACKAGE_EXTRA_INDEX_URL=https://pypi.org/simple/

# Clone-mode settings (used when RR_PIPELINE_INSTALL_MODE=clone)
RR_REPOSITORY_CLONE_URL=
RR_REPOSITORY_DIR=
RR_REPOSITORY_REF=

# chat_completions (default/stateless) | responses (stateful; use only if org/backend supports it)
MODEL_ENDPOINT=chat_completions

# Responses API reasoning effort: low | medium | high
LLM_API_REASONING_EFFORT=high
