# Required by all reflex-package commands
TEAM_NAME=team-dev
DRAFT_MODEL=
LLM_API_BASE_URL=https://llm-api.example.com

# Required by review/distill (VCS context)
VCS_TYPE=bitbucket
VCS_BASE_URL=https://bitbucket.example.com
VCS_PROJECT_KEY=PROJECT
VCS_REPO_SLUG=repository-name
VCS_PR_ID=
VCS_TOKEN=

# Required only by review
JUDGE_MODEL=

# Required by distill/refine
DPO_TRAINING_DATA_DIR=data

# Auth: choose one
LLM_API_KEY=
OAUTH2_TOKEN_URL=https://iam.example.com/oauth2/v1/token
OAUTH2_USER_ID=
OAUTH2_USER_SECRET=

# Optional runtime controls
LLM_API_PROXY_URL=
LLM_API_READ_TIMEOUT_SECONDS=120
STREAM_RESPONSE=false
MODEL_ENDPOINT=chat_completions
LLM_API_REASONING_EFFORT=high
